{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User profile photo URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" },
        "lastLogin": { "type": "string", "format": "date-time", "description": "Last login timestamp" }
      },
      "required": ["uid", "email"]
    },
    "Analysis": {
      "title": "Analysis",
      "description": "Genomic analysis results",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user who ran the analysis" },
        "fileName": { "type": "string", "description": "Name of the analyzed file" },
        "fileType": { "type": "string", "description": "Type of file (VCF, BAM, etc.)" },
        "result": { "type": "string", "description": "JSON string of the analysis result" },
        "summary": { "type": "string", "description": "Human-readable summary" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the analysis was performed" }
      },
      "required": ["userId", "fileName", "result", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/analyses/{analysisId}": {
      "schema": "Analysis",
      "description": "Stored analysis results"
    }
  }
}
